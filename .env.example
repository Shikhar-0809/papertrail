# ExamShield Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git

# Required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
EXAMSHIELD_MASTER_KEY=your-64-char-hex-string-here

# Optional — defaults shown
EXAMSHIELD_DB_PATH=examshield.db
EXAMSHIELD_UPLOADS_DIR=/tmp/examshield_uploads
EXAMSHIELD_ALLOWED_ORIGINS=http://localhost:3000
